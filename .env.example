APP_NAME="MyERP"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_TIMEZONE=Asia/Phnom_Penh

# Frontend SPA dev origin. Used by:
#   • Sanctum stateful detection (SANCTUM_STATEFUL_DOMAINS derives from this)
#   • Backend-rendered email URLs (invitation accept link, future password
#     reset link, etc.) — see config('app.frontend_url')
# Laravel 11+ defaults this to http://localhost:3000 (Sanctum SPA convention).
# Vite's default port is 5173, which is what the frontend/ repo uses.
FRONTEND_URL=http://localhost:5173

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# --- Database (PostgreSQL only — MySQL not supported) ---
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=erp
DB_USERNAME=postgres
DB_PASSWORD=
DB_SCHEMA=public

# --- Redis (cache, queue, session, rate limiting) ---
# Using predis (pure PHP). Switch to phpredis after dropping
# php_redis.dll (PHP 8.4 TS x64 VS17) into C:\xampp\php-8.4.21\ext\.
REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=null
REDIS_DB=0
REDIS_CACHE_DB=1

CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=480
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=localhost

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# --- Mail ---
# Dev default: log driver (writes emails to storage/logs/laravel.log).
# Mailtrap workflow: set MAIL_MAILER=smtp + MAIL_USERNAME + MAIL_PASSWORD
# from your Mailtrap inbox credentials, then `php artisan config:clear`.
# Production: Resend (or any SMTP). Custom domain swap = MAIL_FROM_ADDRESS
# env change only, no code change.
MAIL_MAILER=log
MAIL_HOST=sandbox.smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="onboarding@resend.dev"
MAIL_FROM_NAME="${APP_NAME}"

# --- Invitations (Phase 2A) ---
# Token lifetime in days for invitation links. Default 7 per locked
# decision. Configurable here so the value can be tuned without a
# code change; no UI exposure in Phase 2A.
INVITATION_TOKEN_LIFETIME_DAYS=7

# --- Search ---
SCOUT_DRIVER=meilisearch
MEILISEARCH_HOST=http://127.0.0.1:7700
MEILISEARCH_KEY=

# --- Auth (Sanctum SPA + first-party clients) ---
SANCTUM_STATEFUL_DOMAINS=localhost,127.0.0.1,localhost:5173

# Optional. Override the precomputed dummy bcrypt hash used by the constant-time
# login path. Leave blank to use the value baked into config/auth.php.
# AUTH_TIMING_DUMMY_HASH=

# --- Observability ---
SENTRY_LARAVEL_DSN=
TELESCOPE_ENABLED=true

# --- Money / Accounting (locked: BCMath scale 4) ---
MONEY_DEFAULT_SCALE=4

# --- Tenancy ---
TENANCY_DEFAULT_TIMEZONE=Asia/Phnom_Penh

# --- AWS (placeholder; wire in if you switch FILESYSTEM_DISK) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false
